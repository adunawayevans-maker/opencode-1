# Git
.git
.gitignore

# Documentation (not needed in image)
*.md
!rootfs/**/*.md

# Development files
.editorconfig
.vscode

# Test infrastructure (not needed in image)
**/test/
**/vitest.config.*

# Dependencies are installed from package-lock at build time; the checked-in
# node_modules include dev deps and would clobber the clean production install
**/node_modules/

# Build artifacts
*.log
